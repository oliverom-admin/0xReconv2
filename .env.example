# ============================================================
# 0xRecon v2 — Environment Variable Template
# Copy to .env and fill in values for local development.
# Never commit .env to source control.
# ============================================================

# ----- Product Identity -----
PRODUCT_ID=0xrecon
# Options: 0xrecon | caip

# ----- API Configuration -----
RECON_SECRET_KEY=change-me-to-a-long-random-string
RECON_JWT_ALGORITHM=HS256
RECON_JWT_EXPIRY_HOURS=8
RECON_JWT_REFRESH_EXPIRY_DAYS=30

# ----- Database -----
DATABASE_URL=postgresql+asyncpg://recon:recon@recon-postgres:5432/recon_db
POSTGRES_USER=recon
POSTGRES_PASSWORD=change-me
POSTGRES_DB=recon_db

# ----- Vault -----
RECON_VAULT_FILE=system_vault.enc
RECON_VAULT_MASTER_PASSWORD=change-me-use-docker-secret-in-production

# ----- Domain -----
RECON_DOMAIN=localhost
RECON_API_URL=https://api.localhost
RECON_APP_URL=https://app.localhost

# ----- CORS -----
RECON_CORS_ORIGINS=https://app.localhost,https://admin.localhost

# ----- Azure (Optional) -----
# AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net/
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# ----- Worker -----
RECON_INVENTORY_SYNC_INTERVAL_SECONDS=60
RECON_WORKER_CONCURRENCY=4

# ----- Logging -----
RECON_LOG_LEVEL=INFO
RECON_LOG_FORMAT=json
