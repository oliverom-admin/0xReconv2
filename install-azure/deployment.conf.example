# =============================================================
# 0xRecon — Deployment Configuration
# =============================================================
# Copy this file to deployment.conf and fill in ALL values
# marked as REQUIRED before running setup.sh.
#
# NEVER commit deployment.conf to git — it contains secrets.
# Only deployment.conf.example is committed.
#
# Full install flow:
#   cp install-azure/deployment.conf.example install-azure/deployment.conf
#   nano install-azure/deployment.conf   <- fill in all REQUIRED values
#   bash install-azure/setup.sh          <- does everything else
# =============================================================


# -- Server ----------------------------------------------------

# REQUIRED — IP address or hostname of this server
# Used in deployment summary and health check output.
DEPLOY_HOST=YOUR_SERVER_IP_OR_HOSTNAME

# REQUIRED — Admin user running setup.sh (your login, not the service account)
DEPLOY_USER=YOUR_ADMIN_USERNAME

# Full path where the application will be installed
DEPLOY_PATH=/opt/0xrecon

# Service account that runs the application and owns the files
SERVICE_ACCOUNT=svc-0xrecon


# -- Domain and URLs -------------------------------------------

# REQUIRED — Root domain you control
# Example: stationhex.co.uk
BASE_DOMAIN=YOUR_BASE_DOMAIN

# REQUIRED — Subdomain prefix
# setup.sh creates two subdomains:
#   api.PREFIX.BASE_DOMAIN    -> recon-api (port 8000)
#   app.PREFIX.BASE_DOMAIN    -> recon-ui  (port 3000)
# Example: demo.recon  ->  api.demo.recon.stationhex.co.uk
SUBDOMAIN_PREFIX=YOUR_SUBDOMAIN_PREFIX

# TLS certificate type
# Options:
#   self-signed   — generated by setup.sh, browser warning expected
#   internal-ca   — provide TLS_CERT_PATH and TLS_KEY_PATH below
#   letsencrypt   — requires public DNS and port 80 accessible (Phase 10)
TLS_TYPE=self-signed

# Required only if TLS_TYPE=internal-ca
TLS_CERT_PATH=
TLS_KEY_PATH=

# TLS certificate validity in days (self-signed only)
TLS_CERT_DAYS=3650


# -- GitHub ----------------------------------------------------

# REQUIRED — GitHub username or organisation that owns the repository
GITHUB_USER=oliverom-admin

# GitHub repository name (case-sensitive)
GITHUB_REPO=0xReconv2

# REQUIRED — Git commit author identity for git config on this server
GIT_USER_NAME="Mark Olivero"
GIT_USER_EMAIL=mark@olivero.co.uk

# DO NOT SET — written automatically by setup.sh after key generation
# DEPLOY_KEY_PATH=


# -- Database --------------------------------------------------

# REQUIRED — PostgreSQL password
# Generate: openssl rand -base64 32
# Must not be: changeme, devpassword, or recon_dev_password
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32


# -- Application -----------------------------------------------

# Port for the recon-api FastAPI service (host-mapped)
RECON_API_PORT=8000

# Port for the recon-ui service (host-mapped)
RECON_UI_PORT=3000

# REQUIRED — Application secret key for JWT signing (HS256)
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# Phase 10: replaced by RS256 key pair
RECON_SECRET_KEY=CHANGE_ME_generate_with_python_secrets_token_hex_32

# REQUIRED — Vault master password (AES-256-GCM)
# Generate: openssl rand -base64 32
# Must be at least 32 characters. Must not be a default value.
RECON_VAULT_MASTER_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32

# Docker Compose project name — namespaces all containers
DOCKER_PROJECT_NAME=0xrecon

# Log retention in days
LOG_RETENTION_DAYS=14


# -- Product Identity ------------------------------------------

# Product ID — determines branding
# Options: 0xrecon | caip
PRODUCT_ID=0xrecon

# Product display name (shown in UI and reports)
PRODUCT_NAME=0xRecon

# Short name
PRODUCT_SHORT_NAME=0xRecon


# -- Initial Admin Account ------------------------------------

# REQUIRED — Credentials for the first admin user
# Created automatically by install.sh via the bootstrap endpoint.
# Change the password immediately after first login.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=CHANGE_ME_strong_password_min_12_chars


# =============================================================
# -- Generated by setup.sh — do not edit below this line --
# =============================================================
